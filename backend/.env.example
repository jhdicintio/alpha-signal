# Path to the Alpha Signal SQLite database (articles + extractions).
# Default if unset: repo root articles.db
# ALPHA_SIGNAL_DB_PATH=../../articles.db

# Optional: CORS origins (comma-separated). Default includes http://localhost:5173 and http://127.0.0.1:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
